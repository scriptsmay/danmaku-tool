# danmaku-tool 配置
# 复制此文件为 .env 并修改

# 服务
DANMAKU_HOST=127.0.0.1
DANMAKU_PORT=18000
DANMAKU_DEBUG=false

# FFmpeg（Windows 上如果不在 PATH 中，填写完整路径）
DANMAKU_FFMPEG_PATH=ffmpeg
DANMAKU_FFPROBE_PATH=ffprobe

# 弹幕压制
DANMAKU_DANMAKU_OUTPUT_DIR=C:\DanmakuOutput
DANMAKU_DANMAKU_BURN_FPS=30

# 本地缓存（NFS/SMB 文件先拷贝到本地 SSD 压制，完成后再回传）
DANMAKU_CACHE_ENABLED=false
DANMAKU_CACHE_DIR=data/cache

# 任务队列（GPU 独占建议设为 1）
DANMAKU_MAX_CONCURRENT_TASKS=1

# 文件浏览器安全：允许浏览的根目录
DANMAKU_ALLOWED_ROOTS=C:\Recordings,C:\DanmakuOutput,D:\Videos

# Webhook（可选，联动 live-recorder-server）
DANMAKU_WEBHOOK_ENABLED=false
DANMAKU_WEBHOOK_CALLBACK_URL=http://your-server:11123/api/danmaku/burn-callback

# 数据库
DANMAKU_DB_PATH=data/danmaku_tool.db

# 日志
DANMAKU_LOG_DIR=data/logs
DANMAKU_LOG_LEVEL=INFO
